# GitHub Personal Access Token с правами на запуск workflows
GITHUB_TOKEN=your_github_token_here
# GitHub username или организация
GITHUB_USER=your_username_here
# Имя репозитория
GITHUB_REPO=sb_srs
# Ветка для workflow_dispatch
GITHUB_REF=master
# Расписание cron (по умолчанию каждые 2 часа)
# CRON_SCHEDULE=0 */2 * * *
